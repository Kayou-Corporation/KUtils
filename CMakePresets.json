{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 29,
    "patch": 5
  },
  "configurePresets": [
    {
      "name": "common",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/TEMP/${presetName}"
    },
    {
      "name": "windows-common",
      "hidden": true,
      "inherits": "common",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "unix-common",
      "hidden": true,
      "inherits": "common",
      "condition": {
        "type": "inList",
        "string": "${hostSystemName}",
        "list": ["Linux", "Darwin"]
      }
    },

    {
      "name": "windows-clang-debug",
      "displayName": "Windows Clang Debug",
      "inherits": "windows-common",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++$env{clang_compiler_v}",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-clang-release",
      "displayName": "Windows Clang Release",
      "inherits": "windows-common",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++$env{clang_compiler_v}",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "windows-gcc-debug",
      "displayName": "Windows GCC Debug",
      "inherits": "windows-common",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "g++$env{gcc_compiler_v}",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-gcc-release",
      "displayName": "Windows GCC Release",
      "inherits": "windows-common",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "g++$env{gcc_compiler_v}",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },

    {
      "name": "unix-clang-debug",
      "displayName": "Unix Clang Debug",
      "inherits": "unix-common",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "unix-clang-release",
      "displayName": "Unix Clang Release",
      "inherits": "unix-common",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },

    {
      "name": "unix-gcc-debug",
      "displayName": "Unix GCC Debug",
      "inherits": "unix-common",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "unix-gcc-release",
      "displayName": "Unix GCC Release",
      "inherits": "unix-common",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },

    {
      "name": "vs2022",
      "displayName": "Visual Studio 2022",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/TEMP/${presetName}",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    }
  ],

  "buildPresets": [
    {
      "name": "Windows Clang Debug",
      "configurePreset": "windows-clang-debug",
      "verbose": true
    },
    {
      "name": "Windows Clang Release",
      "configurePreset": "windows-clang-release",
      "verbose": true
    },
    {
      "name": "Windows GCC Debug",
      "configurePreset": "windows-gcc-debug",
      "verbose": true
    },
    {
      "name": "Windows GCC Release",
      "configurePreset": "windows-gcc-release",
      "verbose": true
    },
    {
      "name": "Unix Clang Debug",
      "configurePreset": "unix-clang-debug",
      "verbose": true
    },
    {
      "name": "Unix Clang Release",
      "configurePreset": "unix-clang-release",
      "verbose": true
    },
    {
      "name": "Unix GCC Debug",
      "configurePreset": "unix-gcc-debug",
      "verbose": true
    },
    {
      "name": "Unix GCC Release",
      "configurePreset": "unix-gcc-release",
      "verbose": true
    },
    {
      "name": "VS2022 Debug",
      "configurePreset": "vs2022",
      "configuration": "Debug",
      "verbose": true,
      "jobs": 8
    },
    {
      "name": "VS2022 Release",
      "configurePreset": "vs2022",
      "configuration": "Release",
      "verbose": true,
      "jobs": 8
    }
  ],

  "testPresets": [
    {
      "name": "test-common",
      "hidden": true,
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": true
      }
    },
    {
      "name": "test-windows-clang-debug",
      "inherits": "test-common",
      "configurePreset": "windows-clang-debug"
    },
    {
      "name": "test-windows-clang-release",
      "inherits": "test-common",
      "configurePreset": "windows-clang-release"
    },
    {
      "name": "test-windows-gcc-debug",
      "inherits": "test-common",
      "configurePreset": "windows-gcc-debug"
    },
    {
      "name": "test-windows-gcc-release",
      "inherits": "test-common",
      "configurePreset": "windows-gcc-release"
    },
    {
      "name": "test-unix-clang-debug",
      "inherits": "test-common",
      "configurePreset": "unix-clang-debug"
    },
    {
      "name": "test-unix-clang-release",
      "inherits": "test-common",
      "configurePreset": "unix-clang-release"
    },
    {
      "name": "test-unix-gcc-debug",
      "inherits": "test-common",
      "configurePreset": "unix-gcc-debug"
    },
    {
      "name": "test-unix-gcc-release",
      "inherits": "test-common",
      "configurePreset": "unix-gcc-release"
    }
  ]
}